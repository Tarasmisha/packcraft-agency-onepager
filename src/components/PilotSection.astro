---
interface Props { title: string; subheadline: string; steps: string[] }
const { title, subheadline, steps } = Astro.props;
---
<section class="rounded-2xl bg-white p-8">
  <h2 class="text-2xl font-semibold text-neutral-950">{title}</h2>
  <p class="mt-3 text-neutral-700">{subheadline}</p>
  <ol class="mt-5 grid gap-3 md:grid-cols-5">
    {steps.map((step) => <li class="rounded-xl bg-neutral-50 p-3 text-sm text-neutral-700">{step}</li>)}
  </ol>
</section>
