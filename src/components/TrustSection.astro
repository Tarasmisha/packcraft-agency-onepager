---
interface Card { title: string; body: string }
interface Props { title: string; cards: Card[] }
const { title, cards } = Astro.props;
---
<section class="rounded-2xl bg-white p-8">
  <h2 class="text-2xl font-semibold text-neutral-950">{title}</h2>
  <div class="mt-5 grid gap-3 md:grid-cols-3">
    {cards.map((card) => (
      <article class="rounded-xl bg-neutral-50 p-4">
        <h3 class="text-base font-semibold text-neutral-900">{card.title}</h3>
        <p class="mt-2 text-sm text-neutral-700">{card.body}</p>
      </article>
    ))}
  </div>
</section>
