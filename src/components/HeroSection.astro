---
interface Props {
  headline: string;
  subheadline: string;
  support: string;
  cta: string;
  snapshot: string[];
}
const { headline, subheadline, support, cta, snapshot } = Astro.props;
---
<section class="rounded-2xl bg-white p-8 md:p-10">
  <div class="grid gap-8 md:grid-cols-[1.4fr,0.8fr]">
    <div>
      <h1 class="text-4xl font-semibold tracking-tight text-neutral-950 md:text-5xl">{headline}</h1>
      <p class="mt-4 text-lg text-neutral-700">{subheadline}</p>
      <p class="mt-4 text-base font-medium text-neutral-900">{support}</p>
      <a href="#pricing" class="mt-6 inline-flex rounded-lg bg-orange-600 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-700">{cta}</a>
    </div>
    <aside class="rounded-xl bg-orange-50 p-5">
      {snapshot.map((line, i) => (
        <p class={i === 0 ? 'text-3xl font-semibold text-neutral-950' : 'mt-2 text-sm text-neutral-700'}>{line}</p>
      ))}
    </aside>
  </div>
</section>
