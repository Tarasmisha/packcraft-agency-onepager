---
interface Props { title: string; body: string; support: string }
const { title, body, support } = Astro.props;
---
<section class="rounded-2xl bg-white p-8">
  <h2 class="text-2xl font-semibold text-neutral-950">{title}</h2>
  <p class="mt-3 text-neutral-700">{body}</p>
  <p class="mt-3 text-neutral-900">{support}</p>
</section>
