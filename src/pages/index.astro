---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="PackCraft Agency One-Pager Scaffold">
  <main class="min-h-screen bg-neutral-50 text-neutral-900">
    <section class="mx-auto max-w-5xl px-6 py-16">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-neutral-500">
        Astro + Tailwind Scaffold
      </p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight">PackCraft Agency One-Pager</h1>
      <p class="mt-4 max-w-2xl text-base text-neutral-600">
        Project scaffold is ready. Content collections, layout, and styles are configured.
      </p>
    </section>
  </main>
</BaseLayout>
